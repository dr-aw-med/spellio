// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Modèles d'authentification
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  role          String    @default("PARENT")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  childProfiles ChildProfile[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ChildProfile {
  id          String   @id @default(cuid())
  userId      String
  name        String
  avatar      String?
  schoolLevel String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  dictationProgress   DictationProgress[]
  dictationAttempts   DictationAttempt[]
  userRewards         UserReward[]

  @@map("child_profiles")
}

// Modèles pour les dictées
model Dictation {
  id               String   @id @default(cuid())
  title            String
  text             String   @db.Text
  level            String   // CP, CE1, CE2, CM1, CM2
  category         String   // orthography, grammar, vocabulary, conjugation
  difficulty       String   // easy, medium, hard
  description      String?  @db.Text
  estimatedDuration Int?    // en minutes
  wordCount        Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  progress   DictationProgress[]
  attempts   DictationAttempt[]

  @@unique([title, level], name: "dictation_title_level_unique")
  @@map("dictations")
}

model DictationProgress {
  id           String   @id @default(cuid())
  profileId    String
  dictationId String
  isCompleted Boolean  @default(false)
  isUnlocked  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile   ChildProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  dictation Dictation    @relation(fields: [dictationId], references: [id], onDelete: Cascade)

  @@unique([profileId, dictationId])
  @@map("dictation_progress")
}

model DictationAttempt {
  id           String   @id @default(cuid())
  profileId    String
  dictationId  String
  score        Float
  accuracy     Float
  wordsCorrect Int
  wordsTotal   Int
  errors       String   @db.Text // JSON stringifié
  duration     Int?     // en secondes
  completedAt  DateTime @default(now())

  profile   ChildProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  dictation Dictation    @relation(fields: [dictationId], references: [id], onDelete: Cascade)

  @@map("dictation_attempts")
}

// Modèles pour les récompenses
model UserReward {
  id         String   @id @default(cuid())
  profileId  String
  rewardType String   // badge, star, unlock
  rewardId   String
  metadata   String?  @db.Text // JSON stringifié
  earnedAt   DateTime @default(now())

  profile ChildProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("user_rewards")
}

