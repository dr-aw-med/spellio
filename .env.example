# Spellio — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# Supabase (obligatoire)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Proxy via Edge Functions (prod)
# Si defini, les appels OCR/TTS/Story passent par les Edge Functions Supabase
# Si vide, les appels vont directement a Gemini (dev uniquement)
VITE_API_URL=https://xxx.supabase.co/functions/v1

# Gemini (dev local uniquement, si VITE_API_URL n'est pas defini)
GEMINI_API_KEY=AIza...
